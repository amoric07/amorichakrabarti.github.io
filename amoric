<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Amori Chakrabarti | Resume</title>

<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@300;400;500&display=swap" rel="stylesheet">

<style>

:root {
    --black: #0a0a0a;
    --white: #ffffff;
    --blue: #bcdcff;
    --gray: #777;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Oswald', sans-serif;
}

html {
    scroll-behavior: smooth;
}

body {
    background-color: var(--white);
    color: var(--black);
}

/* Container */
.container {
    max-width: 1000px;
    margin: 40px auto;
    padding: 20px;
}

/* Header */
.header {
    border-bottom: 1px solid var(--black);
    padding-bottom: 20px;
    margin-bottom: 40px;
}

.header h1 {
    font-size: 38px;
    letter-spacing: 2px;
}

.header p {
    font-size: 14px;
    color: var(--gray);
    margin-top: 10px;
}

/* Accent */
.accent {
    width: 50px;
    height: 3px;
    background-color: var(--blue);
    margin: 10px 0 20px;
}

/* Sections */
.section {
    margin-bottom: 40px;
}

.section h2 {
    font-size: 20px;
    letter-spacing: 1px;
}

.section p {
    font-size: 14px;
    margin-bottom: 10px;
}

ul {
    list-style: none;
}

li {
    margin-bottom: 6px;
    font-size: 14px;
}

/* Grid */
.grid {
    display: flex;
    gap: 40px;
    flex-wrap: wrap;
}

.grid > div {
    flex: 1;
    min-width: 250px;
}

/* Items */
.item {
    margin-bottom: 12px;
}

.item span {
    display: block;
    font-size: 13px;
    color: var(--gray);
}

/* Note */
.note {
    font-size: 13px;
    color: var(--gray);
}

/* Back to top */
.top-btn {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background-color: var(--black);
    color: var(--white);
    padding: 8px 12px;
    text-decoration: none;
    font-size: 13px;
}

.top-btn:hover {
    background-color: var(--blue);
    color: var(--black);
}

</style>
</head>